# Frontend Environment Variables
# IMPORTANT: Must start with REACT_APP_ to be included in the build

# API Base URL for HTTP requests
REACT_APP_API_URL=https://boost-art-backend.onrender.com

# Socket.io Base URL (optional - falls back to REACT_APP_API_URL)
REACT_APP_SOCKET_URL=https://boost-art-backend.onrender.com

