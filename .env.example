# Backend Environment Variables

# MongoDB Atlas connection string (REQUIRED in production)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/boostart

# JWT Secret for signing tokens (change to a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-here

# Frontend URL for CORS
FRONTEND_URL=https://boost-art-drab.vercel.app

# API Base URL (used for generating upload URLs)
API_BASE_URL=https://boost-art-backend.onrender.com

# Node environment
NODE_ENV=production

# Render sets PORT automatically (default 5000 for local dev)
PORT=5000

